  "components": {
    "schemas": {
      "ChangePasswordDto": {
        "required": [
          "newPassword",
          "oldPassword"
        ],
        "type": "object",
        "properties": {
          "oldPassword": {
            "minLength": 1,
            "type": "string"
          },
          "newPassword": {
            "maxLength": 100,
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ChangeRoleDto": {
        "required": [
          "role"
        ],
        "type": "object",
        "properties": {
          "role": {
            "minLength": 1,
            "pattern": "^(Student|Admin)$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAnswerDto": {
        "required": [
          "answerText"
        ],
        "type": "object",
        "properties": {
          "answerText": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "imageUrl": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "isCorrect": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "CreateUpdateGradeDto": {
        "required": [
          "gradeName"
        ],
        "type": "object",
        "properties": {
          "gradeName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "orderIndex": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateUpdateQuizDto": {
        "required": [
          "answers",
          "questionText",
          "questionType",
          "unitId"
        ],
        "type": "object",
        "properties": {
          "unitId": {
            "type": "integer",
            "format": "int32"
          },
          "questionText": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "questionType": {
            "minLength": 1,
            "pattern": "^(text|image|audio)$",
            "type": "string"
          },
          "imageUrl": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "ttsText": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "answers": {
            "minItems": 2,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateAnswerDto"
            }
          }
        },
        "additionalProperties": false
      },
      "CreateUpdateUnitDto": {
        "required": [
          "gradeId",
          "title"
        ],
        "type": "object",
        "properties": {
          "gradeId": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "description": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "imageUrl": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "orderIndex": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreateUpdateVocabDto": {
        "required": [
          "mean",
          "unitId",
